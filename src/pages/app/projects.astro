---
/**
 * /app/projects — Projects view.
 * Heading + thesis intro, then ProjectGrid (renders all projects).
 * D14: ProjectGrid is the canonical renderer; no per-view fork.
 */
import AppShellLayout from '../../layouts/AppShellLayout.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { viewStack, viewH1, viewIntro } from '../../styles/appView.css';
import { projectsThesis } from '../../data/projects';
---

<AppShellLayout
  title="Projects — Mike Arnett · Senior Full-Stack Software Engineer"
  description="Mike Arnett's projects — composable AI and programmatic pipelines, domain-agnostic engines."
  activeView="projects"
  viewLabel="Projects"
>
  <section class={viewStack} aria-label="Projects">
    <header>
      <h1 class={viewH1}>Projects</h1>
      <p class={viewIntro}>{projectsThesis}</p>
    </header>

    <ProjectGrid caseStudyBase="/app/projects" />
  </section>
</AppShellLayout>

<style is:global>
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(14px);
      animation: viewRise 600ms cubic-bezier(.2,.7,.2,1) forwards;
    }
    .reveal:nth-child(2)  { animation-delay: 60ms;  }
    .reveal:nth-child(3)  { animation-delay: 120ms; }
    .reveal:nth-child(4)  { animation-delay: 180ms; }
    .reveal:nth-child(5)  { animation-delay: 240ms; }
    .reveal:nth-child(6)  { animation-delay: 300ms; }
    .reveal:nth-child(7)  { animation-delay: 360ms; }
    .reveal:nth-child(8)  { animation-delay: 420ms; }
    @keyframes viewRise {
      to { opacity: 1; transform: none; }
    }
  }
  .mono {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-variant-numeric: tabular-nums;
  }
</style>
