---
/**
 * SiteHead — shared <head> metadata for every layout (single source; dedups the
 * font links that were duplicated across BaseLayout + AppShellLayout).
 * Covers SEO + social: canonical, Open Graph, Twitter, theme-color, favicon,
 * generator. Per-layout concerns (ThemeScript, ClientRouter) stay in the layouts.
 */
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// Canonical absolute URL from the configured `site` + current path (D3 root site).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'Mike Arnett';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="theme-color" content="#0e0f13" />

{/* Open Graph */}
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />

{/* Twitter */}
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />

{/* Fonts — Sora + Space Grotesk + Newsreader + Fraunces + Inter + JetBrains Mono
    cover the four themes' display/body/mono pairings (D5). */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Fraunces:opsz,wght@9..144,300..600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
  rel="stylesheet"
/>
