---
/**
 * ScopeViz — inline-SVG radial relationship mini-viz.
 * Config/data-driven (D18): nodes + core are props.
 * Token-styled (accent + line colours via CSS custom props), works in all 4 themes.
 * Animations gated by prefers-reduced-motion (CSS).
 */
import {
  scopeVizContainer, scopeVizSvg, scopePulse,
  scopeLegend, scopeLegendItem, scopeLegendDot,
} from './ScopeViz.css';

export interface ScopeNode {
  cx: number;
  cy: number;
  label: string;
  delay?: string;
}

interface Props {
  /** Core node label (two lines max, split on newline). */
  coreLabel?: string;
  /** Satellite nodes. */
  nodes?: ScopeNode[];
  ariaLabel?: string;
}

const {
  coreLabel = 'scoped\ncore',
  nodes = [
    { cx: 60,  cy: 45,  label: 'dispatch', delay: '0s'    },
    { cx: 240, cy: 45,  label: 'routing',  delay: '0.4s'  },
    { cx: 60,  cy: 155, label: 'approval', delay: '0.8s'  },
    { cx: 240, cy: 155, label: 'audit',    delay: '1.2s'  },
  ],
  ariaLabel = 'Relationship diagram: a scoped, auditable core mediates channels — dispatch, routing, approval and audit. Every channel is owned, logged and gateable.',
} = Astro.props;

const [coreLine1, coreLine2] = coreLabel.split('\n');
---

<div class={scopeVizContainer}>
  <svg
    class={scopeVizSvg}
    viewBox="0 0 300 200"
    role="img"
    aria-label={ariaLabel}
  >
    <!-- Connecting lines -->
    <g stroke="oklch(70% 0.15 var(--accent-hue, 265) / 0.30)" stroke-width="1.5" fill="none">
      {nodes.map(n => (
        <line x1="150" y1="100" x2={n.cx} y2={n.cy} />
      ))}
    </g>

    <!-- Satellite nodes -->
    {nodes.map(n => (
      <circle
        class={scopePulse}
        cx={n.cx}
        cy={n.cy}
        r="9"
        fill="oklch(70% 0.15 var(--accent-hue, 265) / 0.14)"
        stroke="oklch(70% 0.15 var(--accent-hue, 265))"
        stroke-width="1.5"
        style={n.delay ? `animation-delay:${n.delay}` : undefined}
      />
    ))}

    <!-- Node labels -->
    {nodes.map(n => (
      <text
        x={n.cx}
        y={n.cy - 16}
        text-anchor="middle"
        fill="currentColor"
        opacity="0.75"
        style="font-size:11px;font-weight:500"
      >{n.label}</text>
    ))}

    <!-- Core ring -->
    <circle
      cx="150"
      cy="100"
      r="38"
      fill="none"
      stroke="oklch(70% 0.15 var(--accent-hue, 265) / 0.30)"
      stroke-width="1.5"
    />
    <!-- Core fill -->
    <circle
      cx="150"
      cy="100"
      r="30"
      fill="oklch(70% 0.15 var(--accent-hue, 265))"
      opacity="0.92"
    />
    <!-- Core labels -->
    <text
      x="150"
      y={coreLine2 ? '97' : '103'}
      text-anchor="middle"
      fill="oklch(18% 0.02 270)"
      style="font-size:12px;font-weight:600"
    >{coreLine1}</text>
    {coreLine2 && (
      <text
        x="150"
        y="112"
        text-anchor="middle"
        fill="oklch(18% 0.02 270)"
        style="font-size:12px;font-weight:600"
      >{coreLine2}</text>
    )}
  </svg>
</div>

<div class={scopeLegend} aria-hidden="true">
  <span class={scopeLegendItem}>
    <i
      class={scopeLegendDot}
      style="background:oklch(70% 0.15 var(--accent-hue, 265))"
    ></i>
    owned core
  </span>
  <span class={scopeLegendItem}>
    <i
      class={scopeLegendDot}
      style="background:oklch(70% 0.15 var(--accent-hue, 265) / 0.14)"
    ></i>
    mediated channel
  </span>
</div>
