---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import ControlPanel from '../components/ControlPanel';
import SiteHead from '../components/SiteHead.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { THEME_DEFAULTS } from '../lib/theme';
import { defaultThemeClass as resolveThemeClass, themeClasses } from '../lib/themeRegistry';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// SSR: apply the default theme class + data-theme / data-layout synchronously.
// Client: the inline pre-paint script below reads localStorage to avoid FOUC.
const defaultTheme = THEME_DEFAULTS.theme;
// BaseLayout is the page-scroll route; SSR a page layout for crawlers + as the
// page-view base (the dashboard default lives at /app — D19/D23). The pre-paint
// script redirects dashboard-default humans from `/` to /app.
const defaultLayout = 'control-plane';

// The theme registry maps theme name → vanilla-extract theme class.
// (VE createTheme classes = THEME axis only — D17)
const defaultThemeClass = resolveThemeClass(defaultTheme);
---

<html
  lang="en-AU"
  class={defaultThemeClass}
  data-theme={defaultTheme}
  data-layout={defaultLayout}
  data-mode={THEME_DEFAULTS.mode}
  data-density={THEME_DEFAULTS.density}
  data-motion="ok"
>
  <head>
    <SiteHead title={title} description={description} />

    {/* Pre-paint theme restore (no FOUC) — shared, mirrored across layouts. */}
    <ThemeScript themeClasses={themeClasses} />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
    {/* Floating design switcher — purely interactive chrome, no SSR needed;
        client:only keeps it off the server render (and off the JS critical path). */}
    <ControlPanel client:only="react" />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) translateY(-150%);
    top: 8px;
    z-index: 100;
    background: var(--accent, oklch(72% 0.16 205));
    color: oklch(16% 0.02 260);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.6rem 1rem;
    border-radius: 4px;
    text-decoration: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .skip-link {
      transition: transform 220ms cubic-bezier(.22,.61,.36,1);
    }
  }
  .skip-link:focus {
    transform: translateX(-50%) translateY(0);
  }
</style>
