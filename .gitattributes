# Enforce LF line endings for all text files (WSL2 → GitHub Pages; CRLF must never land)
* text=auto eol=lf

# Explicit text files — source
*.ts   text eol=lf
*.tsx  text eol=lf
*.astro text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Binaries — never diff or merge
*.png  binary
*.jpg  binary
*.svg  binary
*.woff2 binary
